<?xml version="1.0"?>
<!-- <robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot"> -->
<robot name="robot">

    <material name="blue">
        <color rgba="0 0 0.8 0.5"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 0.5"/>
    </material>

    <material name="green">
        <color rgba="0 1 0 0.5"/>
    </material>

    <material name="yellow">
        <color rgba="1 1 0 0.5"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 0.5"/>
    </material>
    
    <link name="base_link">
        <visual>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0" />
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="joint_0" type="revolute">
        <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="link_0"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-4" upper="4" effort="1000.0" velocity="1000.0"/>
    </joint>
   
    <link name="link_0">
        <visual>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0" />
            <geometry>
                <cylinder radius="0.05" length="0.2"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="joint_1" type="revolute">
        <origin xyz="0.0 0.0 0.1" rpy="1.570796 0 0"/>
        <parent link="link_0"/>
        <child link="link_1"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-4" upper="4" effort="1000.0" velocity="1000.0"/>
    </joint>

    <link name="link_1">
        <visual>
            <origin rpy="0 1.570796 0" xyz="0.3 0.0 0.0" />
            <geometry>
                <cylinder radius="0.05" length="0.6"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="joint_2" type="revolute">
        <origin xyz="0.6 0.0 0.0" rpy=" 0.0  0.0  0.0"/>
        <parent link="link_1"/>
        <child link="link_2"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-4" upper="4" effort="1000.0" velocity="1000.0"/>
    </joint>

    <link name="link_2">
        <visual>
            <origin rpy="0 1.570796 0" xyz="0.4 0.0 0.0" />
            <geometry>
                <cylinder radius="0.05" length="0.8"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="joint_3" type="revolute">
        <origin xyz="0.8 0.0 0.0" rpy="1.57 0.0 1.570796"/>
        <parent link="link_2"/>
        <child link="link_21"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-4" upper="4" effort="1000.0" velocity="1000.0"/>
    </joint>

    <link name="link_21">
        <visual>
            <origin rpy="0 0.0 0" xyz="0.0 0.0 0.0" />
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="joint_4" type="revolute">
        <origin xyz="0.0 0.0 0.0" rpy="-1.570796 0.0 0.0"/>
        <parent link="link_21"/>
        <child link="link_22"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-4" upper="4" effort="1000.0" velocity="1000.0"/>
    </joint>

    <link name="link_22">
        <visual>
            <origin rpy="0 0.0 0" xyz="0.0 0.0 0.0" />
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <material name="green"/>
        </visual>
    </link>

    <joint name="joint_5" type="revolute">
        <origin xyz="0.0 0.0 0.0" rpy="1.570796 1.570796 0.0"/>
        <parent link="link_22"/>
        <child link="link_23"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-4" upper="4" effort="1000.0" velocity="1000.0"/>
    </joint>

    <link name="link_23">
        <visual>
            <origin rpy="0 0.0 0" xyz="0.0 0.0 0.0" />
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <material name="yellow"/>
        </visual>
    </link>


</robot>
